{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "develop": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "typescript-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "i18n-check": {
      "outputs": []
    },
    "lint-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "prettier-check": {
      "outputs": []
    },
    "lint-fix": {
      "cache": false
    },
    "prettier-fix": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
