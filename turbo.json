{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "typescript-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "prettier-check": {
      "outputs": []
    },
    "lint-fix": {
      "cache": false
    },
    "prettier-fix": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
