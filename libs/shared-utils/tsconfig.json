{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext"
    // "allowJs": true // for prisma generated client
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
