{
  "name": "@vagabond/shared-utils",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prisma-generate": "pnpx prisma generate --schema=src/db/api-schema.prisma",
    "prisma-generate-watch": "pnpx prisma generate --schema=src/db/api-schema.prisma --watch",
    "prisma-migrate-dev": "pnpx prisma migrate dev --schema=src/db/api-schema.prisma",
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "dev": "pnpm run build && concurrently -k -p \"[{name}]\" -n \"TypeScript,Prisma\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch\" \"pnpm:prisma-generate-watch\""
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
