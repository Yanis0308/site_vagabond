{
  "name": "@vagabond/database-client",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "drizzle-generate": "drizzle-kit generate",
    "build": "pnpm run clean && tsc && cp -r src/migrations dist/migrations",
    "watch": "pnpm run clean && tsc --watch",
    "clean": "rm -rf dist",
    "develop": "concurrently -k -p \"[{name}]\" -n \"TypeScript,Drizzle\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch\" \"pnpm:drizzle-generate\"",
    "postinstall": "pnpm run build"
  },
  "dependencies": {
    "@vagabond/shared-utils": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.11",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.9.2"
  }
}
