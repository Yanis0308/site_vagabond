{
  "name": "@vagabond/database-client",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prisma-generate": "pnpx prisma generate --schema=src/db/api-schema.prisma",
    "prisma-generate-watch": "pnpx prisma generate --schema=src/db/api-schema.prisma --watch",
    "prisma-migrate-dev": "pnpx prisma migrate dev --schema=src/db/api-schema.prisma",
    "build": "pnpm run clean && tsc && cp -r src/db/generated dist/db/generated",
    "watch": "pnpm run clean && tsc --watch",
    "clean": "rm -rf dist",
    "develop": "concurrently -k -p \"[{name}]\" -n \"TypeScript,Prisma\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch\" \"pnpm:prisma-generate-watch\"",
    "postinstall": "pnpm run prisma-generate && pnpm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@vagabond/shared-utils": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^6.3.1",
    "typescript": "^5.6.2"
  }
}
