{
  "name": "@vagabond/database-client",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "typescript-check": "tsc --noEmit",
    "lint-check": "eslint . --max-warnings 0",
    "lint-fix": "eslint . --fix",
    "prettier-check": "prettier . --check",
    "prettier-fix": "prettier . --write",
    "drizzle-generate": "drizzle-kit generate",
    "build": "pnpm run clean && tsc && cp -r src/migrations dist/migrations",
    "clean": "rm -rf dist",
    "develop": "tsc --watch --preserveWatchOutput"
  },
  "dependencies": {
    "@vagabond/shared-utils": "workspace:*",
    "drizzle-orm": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.11",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.9.2",
    "eslint": "catalog:"
  }
}
