{
  "name": "@vagabond/database-client",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prisma-generate": "pnpm exec prisma generate --schema=src/db/api-schema.prisma",
    "prisma-generate-watch": "pnpm exec prisma generate --schema=src/db/api-schema.prisma --watch",
    "prisma-migrate-dev": "pnpm exec prisma migrate dev --schema=src/db/api-schema.prisma",
    "build": "pnpm run clean && tsc && cp -r src/db/generated dist/db/generated",
    "watch": "pnpm run clean && tsc --watch",
    "clean": "rm -rf dist",
    "develop": "concurrently -k -p \"[{name}]\" -n \"TypeScript,Prisma\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch\" \"pnpm:prisma-generate-watch\"",
    "postinstall": "pnpm run prisma-generate && pnpm run build"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@vagabond/shared-utils": "workspace:*",
    "pg": "^8.13.1",
    "prisma": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.11.11",
    "dotenv": "^16.4.5",
    "typescript": "catalog:"
  }
}
