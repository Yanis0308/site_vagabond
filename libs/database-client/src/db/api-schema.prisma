generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "strictUndefinedChecks", "typedSql"]
  output          = "generated/client"
}

datasource db {
  provider   = "postgresql"
  url        = env("API_DATABASE_URL")
  extensions = [postgis]
}

model User {
  id        String   @id @map("user_id") @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  email          String?  @map("email") @db.VarChar(1000)
  fullName       String?  @map("full_name") @db.VarChar(1000)
  oauthProviders String[] @map("oauth_providers") @db.VarChar(1000)
  lastLogin      DateTime @default(now()) @map("last_login")
  role           RoleEnum @default(USER) @map("role")

  visitedPois VisitedPoi[]

  @@map("users")
}

enum RoleEnum {
  ADMIN
  USER
}

model Poi {
  id        String   @id @map("id") @db.VarChar(1000) // format is {source}-{sourceId}, for example "[OSM]-[N-1234567890]"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  source         PoiSourceEnum                        @map("source")
  sourceId       String                               @map("source_id") @db.VarChar(1000)
  coords         Unsupported("geometry(Point, 4326)") @map("coords")
  disabled       Boolean                              @default(false) @map("disabled")
  disabledReason String?                              @map("disabled_reason") @db.VarChar(1000)
  filterLevel    PoiFilterLevelEnum                   @default(UNKNOWN) @map("filter_level")

  // Relations
  poiBoundaries PoiBoundary[]

  @@unique(name: "unique_source_and_source_id", [source, sourceId])
  @@index([coords], name: "coords_index", type: Gist)
  @@map("pois")
}

enum PoiSourceEnum {
  OSM
}

enum PoiFilterLevelEnum {
  UNKNOWN
  STRICT
  STANDARD
  INTERMEDIATE
  LAXIST
}

model PoiData {
  id        Int      @id @default(autoincrement()) @map("id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  name        String            @map("name") @db.VarChar(1000)
  description String            @map("description") @db.VarChar(1000)
  rawInfo     Json              @map("raw_info")
  source      PoiDataSourceEnum @map("source")
  sourceId    String            @map("source_id") @db.VarChar(1000)
  language    LanguageEnum      @map("language")
  nbOfTags    Int?              @map("nb_of_tags")

  poiId String @map("poi_id") @db.VarChar(1000)

  @@unique(name: "unique_source_and_source_id_and_language", [source, sourceId, language])
  @@unique(name: "unique_source_and_poi_id_and_language", [source, poiId, language])
  @@map("poi_data")
}

enum PoiDataSourceEnum {
  OSM
  AI
  CUSTOM
}

enum LanguageEnum {
  EN
  FR
}

model VisitedPoi {
  id        Int      @id @default(autoincrement()) @map("id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  imageKey String                               @map("image_key") @db.VarChar(1000)
  rating   Int                                  @map("rating")
  comment  String                               @map("comment") @db.VarChar(10000)
  coords   Unsupported("geometry(Point, 4326)") @map("coords")

  poiId String @map("poi_id") @db.VarChar(1000)

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id") @db.VarChar(1000)

  @@unique(name: "unique_user_poi", [userId, poiId])
  @@map("visited_pois")
}

enum VisitedPoiStatus {
  PENDING
  CONFIRMED
}

model Boundary {
  id        String   @id @map("id") @db.VarChar(1000) // format is {source}-{sourceId}, for example "[OSM]-[R-1234567890]"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  name          String?                                     @map("name") @db.VarChar(1000)
  boundaryLevel BoundaryLevelEnum                           @map("boundary_level")
  rawInfo       Json                                        @map("raw_info")

  // Hierarchy relation
  parentId String? @map("parent_id") @db.VarChar(1000)

  // Placenames display fields (consolidated from admin_centres)
  displayPoint    Unsupported("geometry(Point, 4326)") @map("display_point") // Point for placename positioning
  placeType       String                               @map("place_type") @db.VarChar(100) // country, state, city, etc.
  population      Int                                  @map("population")
  isCapital       Boolean                              @map("is_capital")
  importanceScore Float                                @map("importance_score") // OSM importance calculation
  wayArea         Float                                @map("way_area") // ST_Area for OSM rendering logic

  // Relations
  poiBoundaries PoiBoundary[]

  // Self-referencing hierarchy
  parent   Boundary?  @relation("BoundaryHierarchy", fields: [parentId], references: [id])
  children Boundary[] @relation("BoundaryHierarchy")

  @@index([boundaryLevel], name: "boundary_level_index")
  @@index([parentId], name: "boundary_parent_index")
  @@index([displayPoint], name: "boundary_display_point_index", type: Gist)
  @@index([importanceScore], name: "boundary_importance_index")
  @@map("boundaries")
}

enum BoundaryLevelEnum {
  COUNTRY // admin_level=2
  REGION // admin_level=4  
  COUNTY // admin_level=6
  CITY // admin_level=8
  DISTRICT // admin_level=9
  NEIGHBORHOOD // admin_level=10
}

model PoiBoundary {
  id        Int      @id @default(autoincrement()) @map("id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  poiId      String @map("poi_id") @db.VarChar(1000)
  boundaryId String @map("boundary_id") @db.VarChar(1000)

  // Relations
  poi      Poi      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  boundary Boundary @relation(fields: [boundaryId], references: [id], onDelete: Cascade)

  @@unique(name: "unique_poi_boundary", [poiId, boundaryId])
  @@map("poi_boundaries")
}
