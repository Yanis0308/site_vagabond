{
  "mcpServers": {
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    },
    "postgres-api": {
      "command": "postgres-mcp",
      "args": ["--access-mode=unrestricted"],
      "env": {
        "DATABASE_URI": "postgresql://username:password@localhost:5432/vagabond"
      }
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=ckykueqammksjvcgfahq&read_only=true"
    },
    "osm-mcp-server": {
      "command": "uvx",
      "args": ["osm-mcp-server"]
    }
  }
}
