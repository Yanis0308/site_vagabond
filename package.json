{
  "name": "vagagond",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "author": "",
  "packageManager": "pnpm@10.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "husky",
    "prettier-write": "prettier . --write",
    "build": "turbo run build",
    "build:libs": "turbo run build --filter=./libs/*",
    "check-all": "turbo run typescript-check lint-check prettier-check i18n-check",
    "check-affected": "turbo run typescript-check lint-check prettier-check i18n-check --filter=[HEAD]",
    "fix-all": "turbo run lint-fix prettier-fix",
    "clean-all": "turbo run clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' \\; -print",
    "develop:api": "turbo watch develop --filter=@vagabond/api",
    "develop:dashboard": "turbo watch develop --filter=@vagabond/dashboard",
    "develop:website": "turbo watch develop --filter=@vagabond/website",
    "develop:mobile": "turbo watch develop --filter=@vagabond/mobile-app",
    "develop:scraper": "turbo watch develop --filter=@vagabond/data-scraper"
  },
  "dependencies": {
    "dayjs": "catalog:",
    "geojson": "catalog:",
    "geolib": "catalog:",
    "typebox": "catalog:",
    "zx": "^8.3.0"
  },
  "devDependencies": {
    "@arthurgeron/eslint-plugin-react-usememo": "^3.0.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
    "@eslint/js": "catalog:",
    "@prettier/plugin-lua": "^0.0.3",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@ts-safeql/eslint-plugin": "^4.2.0",
    "@types/geojson": "catalog:",
    "concurrently": "^9.1.2",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-goodeffects": "^1.0.2",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react-you-might-not-need-an-effect": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "eslint-plugin-tailwindcss": "catalog:",
    "husky": "^9.1.6",
    "libpg-query": "^17.1.1",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "utility-types": "^3.11.0"
  },
  "pnpm": {
    "overrides": {
      "@gluestack-ui/linear-gradient>expo-linear-gradient": "~15.0.7",
      "@vagabond/shared-utils>ajv": "catalog:",
      "@vagabond/shared-utils>dotenv": "catalog:",
      "@vagabond/mobile-app>ajv": "catalog:",
      "basic-ftp": ">=5.2.0",
      "pg": "8.20.0"
    },
    "patchedDependencies": {
      "ajv@8.17.1": "patches/ajv@8.17.1.patch",
      "fastify": "patches/fastify.patch",
      "@nandorojo/galeria@3.0.0": "patches/@nandorojo__galeria@3.0.0.patch"
    }
  },
  "volta": {
    "node": "22.22.2"
  }
}
