{
  "name": "vagagond",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "author": "",
  "packageManager": "pnpm@10.1.0",
  "scripts": {
    "prepare": "husky",
    "prettier-write": "prettier . --write",
    "check-all": "pnpm -r run typescript-check && pnpm -r run lint-check && pnpm -r run prettier-check",
    "fix-all": "pnpm -r run lint-fix && pnpm -r run prettier-fix",
    "clean-all": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' \\; -print"
  },
  "dependencies": {
    "dayjs": "catalog:",
    "geojson": "catalog:",
    "geolib": "catalog:",
    "typebox": "catalog:",
    "zx": "^8.3.0"
  },
  "devDependencies": {
    "@arthurgeron/eslint-plugin-react-usememo": "^3.0.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
    "@eslint/js": "catalog:",
    "@prettier/plugin-lua": "^0.0.3",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@ts-safeql/eslint-plugin": "^4.2.0",
    "@types/geojson": "catalog:",
    "concurrently": "^9.1.2",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-goodeffects": "^1.0.2",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react-you-might-not-need-an-effect": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "eslint-plugin-tailwindcss": "catalog:",
    "husky": "^9.1.6",
    "libpg-query": "^17.1.1",
    "prettier": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "utility-types": "^3.11.0"
  },
  "pnpm": {
    "overrides": {
      "@gluestack-ui/linear-gradient>expo-linear-gradient": "~15.0.7",
      "@vagabond/shared-utils>ajv": "catalog:",
      "@vagabond/shared-utils>dotenv": "catalog:",
      "@vagabond/mobile-app>ajv": "catalog:"
    },
    "patchedDependencies": {
      "ajv@8.17.1": "patches/ajv@8.17.1.patch",
      "fastify": "patches/fastify.patch"
    }
  }
}
