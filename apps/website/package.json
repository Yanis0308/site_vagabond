{
  "name": "@vagabond/website",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "develop": "next dev --turbopack -p ${WEBSITE_PORT:-3001}",
    "build": "NODE_OPTIONS='--conditions react-server' payload generate:importmap && next build",
    "ci": "payload migrate && pnpm build",
    "start": "next start",
    "typescript-check": "tsc --noEmit",
    "lint-check": "node ../../scripts/eslint-retry.mjs . --max-warnings 0",
    "lint-fix": "eslint . --fix",
    "prettier-fix": "prettier . --write",
    "prettier-check": "prettier . --check",
    "seed": "node --env-file=.env.local --import tsx/esm scripts/seed.ts",
    "docker:up": "docker compose -f dev/docker-compose.yml up -d",
    "docker:down": "docker compose -f dev/docker-compose.yml down"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@payloadcms/db-postgres": "3.80.0",
    "@payloadcms/next": "3.80.0",
    "@payloadcms/richtext-lexical": "3.80.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.8.1",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "payload": "3.80.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.2",
    "smartbanner.js": "^1.28.1",
    "tailwind-merge": "^3.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "pg": "catalog:",
    "postcss": "^8",
    "prettier": "catalog:",
    "tailwindcss": "^4.1.18",
    "shadcn": "^4.0.5",
    "typescript": "catalog:"
  }
}
