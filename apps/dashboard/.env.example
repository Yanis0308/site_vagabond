# Supabase Auth — projet Supabase existant (celui qui sert déjà la DB applicative).
# URL et publishable key disponibles dans Supabase Studio → Settings → API Keys.
# Format publishable: sb_publishable_xxxxxxxxxxxxxxxx (nouveau système 2025+,
# remplace l'ancienne "anon key" étiquetée "Legacy").
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Next dev listen port (used by pnpm develop script in package.json, not parsed in app code)
# DASHBOARD_PORT=3002

# API Fastify — base URL des endpoints /api/dashboard/* (appels client-first via ky).
NEXT_PUBLIC_API_URL=http://localhost:3000
