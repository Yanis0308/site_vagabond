{
  "type": "module",
  "name": "@vagabond/api",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "version": "1.0.0",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "typescript-check": "tsc --noEmit",
    "lint-check": "eslint .",
    "prettier-check": "prettier . --check",
    "clean": "rimraf dist",
    "prebuild": "pnpm run clean",
    "test": "pnpm run build:ts && tsc -p test/tsconfig.json && FASTIFY_AUTOLOAD_TYPESCRIPT=1 node --test --experimental-test-coverage --loader ts-node/esm test/**/*.ts",
    "start": "pnpm run build:ts && fastify start -l info dist/app.js",
    "build": "tsc",
    "watch": "tsc -w",
    "develop": "pnpm run build && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch\" \"pnpm:dev:start\"",
    "dev:start": "fastify start --ignore-watch='.ts$ .json$' -w -l info -P dist/app.js"
  },
  "keywords": [],
  "author": "",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@fastify/type-provider-typebox": "^5.0.1",
    "@vagabond/shared-utils": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.0.1",
    "fastify-plugin": "^5.0.0",
    "firebase-admin": "^13.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "c8": "^10.1.2",
    "concurrently": "^9.0.0",
    "eslint": "~8.57.0",
    "fastify-tsconfig": "^2.0.0",
    "libpg-query": "^16.3.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.4.0",
    "typescript": "^5.6.2"
  }
}
