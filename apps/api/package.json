{
  "type": "module",
  "name": "@vagabond/api",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "version": "1.0.0",
  "files": [
    "dist",
    "instrument.mjs",
    "package.json"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "typescript-check": "tsc --noEmit",
    "lint-check": "eslint . --max-warnings 0",
    "lint-fix": "eslint . --fix",
    "prettier-check": "prettier . --check",
    "prettier-fix": "prettier . --write",
    "clean": "rimraf dist",
    "prebuild": "pnpm run clean",
    "test": "pnpm run build && tsc -p test/tsconfig.json && node --test --experimental-test-coverage --loader ts-node/esm test/**/*.ts",
    "start": "node --import ./instrument.mjs dist/server.js",
    "build": "tsc",
    "develop": "NODE_ENV=development tsc-watch --onSuccess 'node ./dist/server.js'"
  },
  "keywords": [],
  "author": "",
  "dependencies": {
    "@ai-sdk/google": "^3.0.6",
    "@ai-sdk/groq": "^3.0.10",
    "@aws-sdk/client-s3": "^3.812.0",
    "@aws-sdk/lib-storage": "^3.815.0",
    "@fastify/compress": "^8.1.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/request-context": "^6.2.1",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sentry/node": "^10.43.0",
    "@slack/web-api": "^7.12.0",
    "@vagabond/api-utils": "workspace:*",
    "@vagabond/database-client": "workspace:*",
    "@vagabond/shared-utils": "workspace:*",
    "ai": "^6.0.28",
    "close-with-grace": "^2.3.0",
    "dayjs": "catalog:",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.0.1",
    "fastify-plugin": "^5.0.0",
    "firebase-admin": "^13.0.1",
    "geolib": "catalog:",
    "gpt-tokenizer": "^3.4.0",
    "ky": "^1.14.2",
    "pino": "^10.3.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sharp": "^0.34.2",
    "unified": "^11.0.5",
    "unist-util-map": "^4.0.0",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "c8": "^10.1.2",
    "eslint": "catalog:",
    "fastify-tsconfig": "^2.0.0",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.4.0",
    "tsc-watch": "^6.2.1",
    "typescript": "catalog:"
  }
}
