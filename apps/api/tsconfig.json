{
  "extends": ["../../tsconfig.base.json", "fastify-tsconfig"],
  "compilerOptions": {
    "outDir": "dist",
    "sourceMap": true,
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "target": "ES2022",
    "esModuleInterop": true,
    // to prevent Prisma runtime errors with undefined values https://www.prisma.io/docs/orm/prisma-client/special-fields-and-types/null-and-undefined
    "exactOptionalPropertyTypes": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["test/**/*.ts", "test/**/*.js"]
}
