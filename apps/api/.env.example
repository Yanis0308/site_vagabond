# Ports (optional — default API 3000)
# PORT=3000

# Firebase Admin SDK
FIREBASE_ADMIN_SERVICE_ACCOUNT_FILE_BASE64=<fill this field>

# Database — for local dev, port must match DOCKER_DB_API_PORT in dev/.env
API_DATABASE_URL="postgresql://user:password@localhost:5432/vagabond"

# S3 Bucket
AWS_ACCESS_KEY_ID=<fill this field>
AWS_SECRET_ACCESS_KEY=<fill this field>
AWS_ENDPOINT_URL_S3=https://t3.storage.dev
# use this URL in fly.io
#AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
AWS_ENDPOINT_URL_IAM=https://fly.iam.storage.tigris.dev
AWS_REGION=auto
S3_BUCKET_NAME=dev-vagabond-public
CDN_URL=https://dev-vagabond-public.t3.storage.dev

# Slack config
SLACK_BOT_AUTH_TOKEN=<fill this field>
SLACK_CHANNEL_SIGNUPS=<fill this field>
SLACK_CHANNEL_POI_VALIDATIONS=<fill this field>
SLACK_CHANNEL_APP_REVIEWS=<fill this field>
SLACK_CHANNEL_POI_REPORTS=<fill this field>
SLACK_CHANNEL_PLACE_SUGGESTIONS=<fill this field>
SLACK_CHANNEL_USER_FEEDBACK=<fill this field>

# Jina API key
JINA_API_KEY=<fill this field>

# LLMs
GEMINI_API_KEY=<fill this field>
GROQ_API_KEY=<fill this field>

# Wikimedia OAuth2
WIKIMEDIA_OAUTH2_CLIENT_ID=<fill this field>
WIKIMEDIA_OAUTH2_CLIENT_SECRET=<fill this field>

# Sentry config
SENTRY_DSN=empty
SENTRY_ENVIRONMENT=local

# App environment
APP_ENV=development

# pg-boss (queue d'enrichissement) — défauts raisonnables, surcharger si besoin
PGBOSS_SCHEMA=pgboss
# Jobs enrich-poi en parallèle PAR instance API (Node event loop unique).
PGBOSS_ENRICHMENT_CONCURRENCY=40
# Rétention des jobs terminés avant suppression auto
PGBOSS_ARCHIVE_DAYS=7

# Supabase Auth (cf. ADR 0002) — utilisé pour valider les JWT envoyés par le
# Dashboard sur les routes /api/dashboard/*. JWKS URL accessible publiquement.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
