{
  "type": "module",
  "name": "@vagabond/data-scraper",
  "description": "Data scraper API with Puppeteer",
  "version": "1.0.0",
  "scripts": {
    "typescript-check": "tsc --noEmit",
    "lint-check": "eslint . --max-warnings 0",
    "clean": "rimraf dist",
    "prebuild": "pnpm run clean",
    "start": "node dist/server.js",
    "build": "tsc",
    "develop": "NODE_ENV=development tsc-watch --onSuccess 'node ./dist/server.js'"
  },
  "dependencies": {
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@vagabond/api-utils": "workspace:*",
    "@vagabond/database-client": "workspace:*",
    "@vagabond/shared-utils": "workspace:*",
    "close-with-grace": "^2.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.0.1",
    "fastify-plugin": "^5.0.0",
    "puppeteer": "^24.34.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "fastify-tsconfig": "^2.0.0",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.4.0",
    "tsc-watch": "^6.2.1",
    "typescript": "catalog:"
  }
}
