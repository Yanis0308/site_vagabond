{
  "name": "@vagabond/mobile-app",
  "old-main": "expo-router/entry",
  "main": "index.js",
  "version": "1.0.0",
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "private": true,
  "scripts": {
    "typescript-check": "tsc --noEmit",
    "i18n-check": "tsx scripts/check-i18n-keys.ts",
    "lint-check": "eslint . --max-warnings 0",
    "lint-check-debug": "eslint . --debug",
    "lint-fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prettier-check": "prettier . --check",
    "prettier-fix": "prettier . --write",
    "develop": "dotenvx run -f .env.local -- sh -c 'expo start --clear --port \"${MOBILE_APP_PORT:-8081}\"'",
    "build-local-ios-simulator": "dotenvx run -f .env.local -- eas build --platform ios --profile development-simulator --local",
    "build-cloud-ios-simulator": "dotenvx run -f .env.local -- eas build --platform ios --profile development-simulator",
    "build-local-ios-dev": "dotenvx run -f .env.local -- eas build --platform ios --profile development --local",
    "build-cloud-ios-dev": "dotenvx run -f .env.local -- eas build --platform ios --profile development",
    "build-local-ios-preview": "dotenvx run -f .env.local -f .env.dev --overload -- eas build --platform ios --profile preview --local",
    "build-cloud-ios-preview": "dotenvx run -f .env.local -f .env.dev --overload -- eas build --platform ios --profile preview",
    "build-local-ios-prd": "dotenvx run -f .env.prd -- eas build --platform ios --profile production --local",
    "build-cloud-ios-prd": "dotenvx run -f .env.prd -- eas build --platform ios --profile production",
    "build-local-android-dev": "dotenvx run -f .env.local -- eas build --platform android --profile development --local",
    "build-cloud-android-dev": "dotenvx run -f .env.local -- eas build --platform android --profile development",
    "build-local-android-preview": "dotenvx run -f .env.local -f .env.dev --overload -- eas build --platform android --profile preview --local",
    "build-cloud-android-preview": "dotenvx run -f .env.local -f .env.dev --overload -- eas build --platform android --profile preview",
    "build-local-android-prd": "dotenvx run -f .env.prd -- eas build --platform android --profile production --local",
    "build-cloud-android-prd": "dotenvx run -f .env.prd -- eas build --platform android --profile production",
    "build-cloud-and-submit-ios-preview": "dotenvx run -f .env.local -- eas build --platform ios --profile preview --submit",
    "submit-ios-preview": "dotenvx run -f .env.local -f .env.dev --overload -- eas submit --platform ios --profile preview",
    "submit-ios-prd": "dotenvx run -f .env.prd -- eas submit --platform ios --profile production",
    "submit-android-preview": "dotenvx run -f .env.local -f .env.dev --overload -- eas submit --platform android --profile preview",
    "submit-android-prd": "dotenvx run -f .env.prd -- eas submit --platform android --profile production",
    "create-update-preview": "dotenvx run -f .env.local -f .env.dev --overload -- zx create-update.mjs --environment preview --message",
    "create-update-prd": "dotenvx run -f .env.prd -- zx create-update.mjs --environment production --message"
  },
